{
  "compilerOptions": {
    "target": "ES2024",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "jsx": "preserve",
    "noEmit": true
  },
  "include": ["web/src", "web/tests", "web/server"],
  "exclude": ["node_modules", "web/.nuxt", "web/.output"]
}
